{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@bvprint/bvshop-api": ["packages/bvshop-api/src/index.ts"],
      "@bvprint/print-core": ["packages/print-core/src/index.ts"],
      "@bvprint/templates": ["packages/templates/src/index.ts"]
    }
  }
}
